{
    "name": "brixel-ext",
    "version": "0.0.3",
    "description": "BRIXEL Extension - Supports 100+ sensors, actuators, displays & communication devices",
    "license": "MIT",
    "author": "BRIXEL",
    "public": true,
    "icon": "./icon.png",
    "dependencies": {
        "core": "*",
        "microbit": "*",
        "bluetooth": "*"
    },
    "yotta": {
        "configIsJustDefaults": true,
        "config": {
            "microbit-dal": {
                "bluetooth": {
                    "enabled": 1,
                    "pairing_mode": 0,
                    "private_addressing": 0,
                    "open": 1,
                    "whitelist": 0,
                    "advertising_timeout": 0,
                    "tx_power": 6,
                    "dfu_service": 0,
                    "event_service": 1,
                    "device_info_service": 1
                }
            }
        }
    },
    "files": [
        "main.ts",
        "01_displays.ts",
        "02_adv_displays.ts",
        "03_sensors.ts",
        "04_adv_sensors.ts",
        "05_actuators.ts",
        "06_output_device.ts",
        "07_communications.ts",
        "08_wifi.ts",
        "09_usb_serial.ts",
        "10_bluetooth.ts",
        "README.md",
        "icon.png",
